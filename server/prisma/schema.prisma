generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id
  email       String   @unique
  name        String?
  avatarUrl   String?
  preferences Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions   Session[]
  vocabulary VocabularyItem[]
  quizAttempts QuizAttempt[]
  seenQuestions UserSeenQuestion[]

  @@map("users")
}

model Session {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenarioId   String
  scenarioName String
  topic        String
  userContext   Json
  startedAt    DateTime        @default(now())
  endedAt      DateTime?
  durationSecs Int?
  messageCount Int             @default(0)

  lessonId   String?
  lessonType String?

  messages   Message[]
  summary    SessionSummary?
  vocabulary VocabularyItem[]

  @@index([userId])
  @@map("sessions")
}

model Message {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  feedback  Json?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("messages")
}

model SessionSummary {
  id                String   @id @default(uuid())
  sessionId         String   @unique
  session           Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  overallScore      Int
  fluencyAssessment String
  grammarSummary    String
  vocabHighlights   String[]
  areasToImprove    String[]
  encouragement     String
  createdAt         DateTime @default(now())

  @@map("session_summaries")
}

model VocabularyItem {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId    String?
  session      Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  word         String
  context      String?
  definition   String?
  mastered     Boolean   @default(false)
  reviewCount  Int       @default(0)
  lastReviewAt DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([word])
  @@map("vocabulary")
}

model QuizQuestion {
  id          String   @id @default(uuid())
  module      String
  prompt      String
  options     String[]
  correctIdx  Int
  explanation String?
  difficulty  String   @default("intermediate")
  createdAt   DateTime @default(now())

  responses QuizResponse[]
  seenBy    UserSeenQuestion[]

  @@index([module])
  @@map("quiz_questions")
}

model QuizAttempt {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  module     String
  mode       String    @default("module")
  score      Int       @default(0)
  total      Int       @default(10)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  responses QuizResponse[]

  @@index([userId])
  @@map("quiz_attempts")
}

model QuizResponse {
  id         String       @id @default(uuid())
  attemptId  String
  attempt    QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  chosenIdx  Int
  correct    Boolean
  answeredAt DateTime     @default(now())

  @@index([attemptId])
  @@map("quiz_responses")
}

model UserSeenQuestion {
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  seenAt     DateTime     @default(now())

  @@id([userId, questionId])
  @@index([userId])
  @@map("user_seen_questions")
}
